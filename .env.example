# Copy to .env (which is gitignored) and fill in your real values.
# The server reads these as environment variables. PowerShell users:
# in pwsh, use: Get-Content .env | foreach { if ($_ -match '^[A-Z]') { $k,$v = $_.Split('=',2); [Environment]::SetEnvironmentVariable($k,$v) } }
# Or just `$env:GITHUB_TOKEN="..."` etc. before `python server.py`.

# Switch the agent: "mock" (default, in-process) or "github" (real workflows).
AGENT_KIND=github

# Fine-grained PAT with: Actions Read & Write, Contents Read, Metadata Read.
# This is sensitive — never commit it.
GITHUB_TOKEN=github_pat_REPLACE_ME

# Repo coordinates.
GITHUB_OWNER=MarchalMaxim
GITHUB_REPO=TheMatrix

# Branch the workflow file lives on (must be pushed to GitHub).
# For first smoke test on the feature branch, set this to feature/matrix-rplace.
# Once merged to main you can drop it (it defaults to main).
GITHUB_REF=main

# (optional) Workflow filename on the branch above. Default: matrix-handoff.yml
# GITHUB_WORKFLOW_FILE=matrix-handoff.yml

# (optional) Token gating the /logs operator page. Any random string.
LOGS_TOKEN=pick-a-random-string
